{
  "id": "bbc_news_headlines",
  "name": "BBC News Headlines",
  "variables": {},
  "steps": [
    {
      "id": "navigate",
      "action": "goto",
      "comment": "Navigate directly to BBC News",
      "params": {
        "url": "https://www.bbc.com/news"
      },
      "timeout": 45000
    },
    {
      "id": "wait_for_page",
      "action": "waitForAny",
      "params": {
        "selectors": [
          "text=BBC News",
          "[data-testid='card-headline']",
          "main h2"
        ],
        "timeout": 10000
      },
      "optional": true
    },
    {
      "id": "extract_headlines",
      "action": "extractDom",
      "comment": "Extract headlines via verified data-testid='card-headline' selector",
      "params": {
        "selector": "[data-testid='card-headline']",
        "max_results": 10
      },
      "store_as": "headlines",
      "validate": {
        "min_length": 50,
        "min_lines": 3,
        "must_not_contain": [
          "CAPTCHA",
          "access denied"
        ]
      }
    },
    {
      "id": "done",
      "action": "done",
      "params": {
        "result": "{{headlines}}"
      }
    }
  ],
  "success_count": 10,
  "fail_count": 0,
  "avg_duration_ms": 3420,
  "last_used": "2026-04-03T09:01:39.747Z",
  "version": 1,
  "domain": "bbc.com",
  "tags": [
    "news",
    "headlines"
  ],
  "match": {
    "keywords": [
      "headlines",
      "news",
      "bbc"
    ],
    "pattern": "(?:headlines|news|top stories).*(?:from\\s+)?(?:bbc|BBC)?"
  },
  "test": {
    "variables": {},
    "expect": {
      "success": true,
      "result_min_length": 100,
      "min_lines": 3,
      "max_duration_ms": 20000
    }
  }
}