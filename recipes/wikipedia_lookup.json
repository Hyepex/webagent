{
  "id": "wikipedia_lookup",
  "name": "Wikipedia Lookup",
  "variables": {
    "topic": {
      "label": "Topic to search",
      "required": true,
      "example": "History of cricket"
    }
  },
  "steps": [
    {
      "id": "build_url",
      "action": "buildUrl",
      "comment": "Build Wikipedia REST API summary URL",
      "params": {
        "builder": "wikipedia",
        "args": {
          "topic": "{{topic}}"
        }
      },
      "store_as": "url",
      "retry": false
    },
    {
      "id": "navigate",
      "action": "goto",
      "comment": "Navigate to API endpoint (returns JSON page)",
      "params": {
        "url": "{{url}}"
      }
    },
    {
      "id": "fetch",
      "action": "fetchJson",
      "comment": "Fetch Wikipedia summary JSON via REST API",
      "params": {
        "url": "{{url}}"
      },
      "store_as": "wiki_json"
    },
    {
      "id": "format",
      "action": "formatJson",
      "comment": "Format the JSON into readable output",
      "params": {
        "source": "wiki_json",
        "fields": [
          {
            "path": "title",
            "label": "Topic"
          },
          {
            "path": "description",
            "label": "Description"
          },
          {
            "path": "extract",
            "label": "Summary"
          }
        ]
      },
      "store_as": "wiki_result",
      "validate": {
        "min_length": 100,
        "must_not_contain": [
          "Wikipedia does not have an article"
        ]
      }
    },
    {
      "id": "done",
      "action": "done",
      "params": {
        "result": "{{wiki_result}}"
      }
    }
  ],
  "success_count": 17,
  "fail_count": 1,
  "avg_duration_ms": 1116,
  "last_used": "2026-04-03T09:27:14.124Z",
  "version": 1,
  "domain": "en.wikipedia.org",
  "tags": [
    "research",
    "wiki"
  ],
  "test": {
    "variables": {
      "topic": "India"
    },
    "expect": {
      "success": true,
      "result_min_length": 200,
      "max_duration_ms": 15000
    }
  },
  "match": {
    "keywords": [
      "wikipedia",
      "wiki"
    ],
    "pattern": "(?:wikipedia|wiki)\\s+(?:about|for|on)\\s+(?<topic>[\\w\\s]+)"
  }
}