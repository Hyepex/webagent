# WebAgent — Recipe-Only Mode (no LLM required)

# ─── Browser Configuration ───────────────────────────────
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000
BROWSER_DEFAULT_TIMEOUT=15000
BROWSER_WIDTH=1280
BROWSER_HEIGHT=800
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...

# ─── Agent Configuration ─────────────────────────────────
MAX_STEPS=30
STEP_TIMEOUT=120000
MAX_ELEMENTS=30
MAX_VISIBLE_TEXT=1500
MAX_GET_TEXT=3000
MAX_HISTORY=14

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/webagent

# ─── Authentication ──────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here
