# ─── LLM Configuration ───────────────────────────────────
LLM_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.1

# ─── Browser Configuration ───────────────────────────────
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000
BROWSER_DEFAULT_TIMEOUT=15000
BROWSER_WIDTH=1280
BROWSER_HEIGHT=800
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...

# ─── Agent Configuration ─────────────────────────────────
MAX_STEPS=20
STEP_TIMEOUT=120000
MAX_ELEMENTS=10
MAX_VISIBLE_TEXT=400
MAX_GET_TEXT=800
MAX_HISTORY=14

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/webagent

# ─── Authentication ──────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here
